# Supabase — Vite is set to load env from `src/` (see vite.config.js → envDir).
# Put this file at:  src/.env   (same folder as main.jsx)
# Or use project root `.env` — then change vite.config.js envDir to: path.resolve(__dirname, '.')
#
# Dashboard: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
